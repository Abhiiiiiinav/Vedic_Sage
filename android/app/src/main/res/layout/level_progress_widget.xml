<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📊 Your Progress"
            android:textColor="#FFFFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lp_level_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Lv. 1"
            android:textColor="#FF00D4FF"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/lp_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <TextView
        android:id="@+id/lp_xp_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 / 200 XP"
        android:textColor="#99FFFFFF"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/lp_chapters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 chapters completed"
        android:textColor="#FF7B61FF"
        android:textSize="11sp"
        android:gravity="center" />

</LinearLayout>
